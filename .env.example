# ReplayMind 配置文件示例
# 复制此文件为 .env 并根据实际情况修改

# 应用配置
APP_NAME=ReplayMind
APP_VERSION=0.1.0
DEBUG=True
API_PREFIX=/api/v1

# 服务器配置
HOST=0.0.0.0
PORT=8000

# PostgreSQL 数据库配置
DATABASE_URL=postgresql://replaymind:replaymind123@localhost:5432/replaymind
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# Milvus 向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=replaymind_

# MinIO 对象存储配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=replaymind
MINIO_SECRET_KEY=replaymind123
MINIO_BUCKET_NAME=replaymind
MINIO_SECURE=False

# DeepSeek 配置（聊天模型使用 DeepSeek API）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Ollama 配置（仅用于视觉模型）
OLLAMA_HOST=http://localhost:11434
OLLAMA_VISION_MODEL=qwen2.5-vl:7b

# Embedding 配置
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32

# Reranker 配置
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cuda
RERANKER_TOP_K=5

# Whisper 配置
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cuda
WHISPER_LANGUAGE=zh

# 视频处理配置
VIDEO_MAX_SIZE_MB=500
VIDEO_KEYFRAME_INTERVAL=2.0

# 日志配置
LOG_LEVEL=INFO
LOG_TO_FILE=True
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# JWT 配置
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 配置
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
